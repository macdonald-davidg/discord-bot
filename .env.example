# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id
GUILD_ID=your_discord_server_id

# Open WebUI API Configuration
# Make sure this URL is publicly accessible from where the bot is hosted
OPEN_WEBUI_URL=https://your-openwebui-domain.com

# API Authentication
# Get your API key from Settings > Account in Open WebUI
OPEN_WEBUI_API_KEY=your_open_webui_api_key

# Default model to use when none is specified in commands
# Use the exact model name as it appears in Open WebUI
OPEN_WEBUI_DEFAULT_MODEL=gpt-4o

# open-terminal (required by the /linux, /docker, /pihole, /proxmox,
# /proxmox-backup, /windows, /fileserver, /unifi-clients, and /unifi-block
# commands — the latter two SSH out to the router to query its Mongo client
# table even though their mutating action goes over the controller's REST
# API instead)
# URL of the open-terminal API and the key that authenticates against it.
# Treat this key like an SSH private key — it grants command execution.
OPEN_TERMINAL_URL=http://203.0.113.5:8100
OPEN_TERMINAL_API_KEY=your_open_terminal_api_key

# UniFi Network/Protect controller (required by /poe, /unifi-restart,
# /unifi-clients, /unifi-block, and /camera-status). This is the self-hosted
# controller running on the router itself. Create a DEDICATED local admin
# account for the bot in the controller UI — do not reuse your personal
# login — and put its credentials here. See README.md's "PoE bounce",
# "UniFi client actions", and "Camera recording status" sections.
# MUST be an IP, not a hostname, if that hostname is a CNAME (e.g. a router
# alias pointing at its real name) — confirmed 2026-07-22 that the bot's
# node:*-alpine image's musl libc DNS resolver doesn't chase CNAMEs the way
# Node's own JS resolver (dns.resolve4) does, so axios/https requests to a
# CNAME hostname fail with ENOTFOUND even though the name resolves fine via
# `nslookup`/`dig`. Using the target's IP directly sidesteps this entirely.
UNIFI_CONTROLLER_URL=https://192.168.1.1
UNIFI_CONTROLLER_USERNAME=your_dedicated_service_account
UNIFI_CONTROLLER_PASSWORD=your_dedicated_service_account_password
# UNIFI_CONTROLLER_SITE=default   # uncomment/change only if you use a non-default site

# Performance Settings
RATE_LIMIT=10  # Maximum API requests per minute
PORT=3001      # Health check server port 