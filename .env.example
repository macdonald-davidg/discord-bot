# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id
GUILD_ID=your_discord_server_id

# Open WebUI API Configuration
# Make sure this URL is publicly accessible from where the bot is hosted
OPEN_WEBUI_URL=https://your-openwebui-domain.com

# API Authentication
# Get your API key from Settings > Account in Open WebUI
OPEN_WEBUI_API_KEY=your_open_webui_api_key

# Default model to use when none is specified in commands
# Use the exact model name as it appears in Open WebUI
OPEN_WEBUI_DEFAULT_MODEL=gpt-4o

# open-terminal (required by the /linux, /docker, /pihole, /proxmox,
# /windows, and /fileserver netcheck commands)
# URL of the open-terminal API and the key that authenticates against it.
# Treat this key like an SSH private key — it grants command execution.
OPEN_TERMINAL_URL=http://203.0.113.5:8100
OPEN_TERMINAL_API_KEY=your_open_terminal_api_key

# Performance Settings
RATE_LIMIT=10  # Maximum API requests per minute
PORT=3001      # Health check server port 